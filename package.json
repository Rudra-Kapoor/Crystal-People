{
  "name": "crystal-people",
  "version": "1.0.0",
  "type": "module",
  "description": "Crystal Group — Employee Performance Management Tool",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"npm run dev --prefix client\"",
    "build": "npm install --prefix client && npm run build --prefix client",
    "install:all": "npm install && npm install --prefix client",
    "start": "node server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
